# Copy this file to .env and edit before first start (never commit .env)
# Docker Compose loads it via env_file in docker-compose.yml

# Required
SECRET_KEY=change-this-to-a-long-random-string

# App
PORT=5050
# IELTS_DB=/app/data/app.db

# Database (default: sqlite — matches current production)
DB_TYPE=sqlite

# Optional scaling (defaults match current prod: 1 worker, 1 thread)
# GUNICORN_WORKERS=1
# GUNICORN_THREADS=8

# PostgreSQL stack (docker-compose.postgres.yml — app + Postgres, one deploy)
# Required when using the Postgres compose file:
# POSTGRES_PASSWORD=change-this-secure-password
# Optional overrides (defaults are set in docker-compose.postgres.yml):
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=4

# Backups (inside container data dir; SQLite only)
BACKUP_ENABLED=1
BACKUP_INTERVAL_DAYS=7

# SMTP (required for forgot-password emails)
SMTP_ENABLED=1
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=IELTS Writing Practice <your-email@gmail.com>
SMTP_USE_TLS=1

# Password reset
RESET_CODE_MINUTES=30

# Optional: if DB is on NFS, set in compose environment instead:
# SQLITE_JOURNAL_MODE=DELETE
